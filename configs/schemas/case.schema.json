{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "case.schema.json",
  "title": "Radar Pipeline Case Schema (v3-fixed)",
  "$comment": "Radar Pipeline Case Schema\n\nPurpose\n-------\nThis JSON Schema defines the strict, versioned contract for runnable radar pipeline case configurations.\n\nCase Types\n----------\nThis schema supports two mutually-exclusive top-level case types via oneOf:\n- performance_case: physical/statistical performance evaluation (model_based)\n- monte_carlo_case: empirical validation experiments (monte_carlo)\n\nStrictness\n----------\n- unevaluatedProperties=false at the top level\n- additionalProperties=false inside major objects\n\nUnits\n-----\nCanonical SI units are expected (Hz, W, m, s). Optional shorthands may be normalized by core/config/units.py.\n",
  "type": "object",
  "oneOf": [
    { "$ref": "#/$defs/performance_case" },
    { "$ref": "#/$defs/monte_carlo_case" }
  ],
  "unevaluatedProperties": false,
  "$defs": {
    "performance_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["radar", "antenna", "receiver", "target"],
      "properties": {
        "radar": { "$ref": "#/$defs/radar" },
        "antenna": { "$ref": "#/$defs/antenna" },
        "receiver": { "$ref": "#/$defs/receiver" },
        "target": { "$ref": "#/$defs/target" },
        "environment": { "$ref": "#/$defs/environment" },
        "detection": { "$ref": "#/$defs/detection" },
        "metrics": { "$ref": "#/$defs/metrics" },
        "geometry": { "$ref": "#/$defs/geometry" }
      }
    },

    "monte_carlo_case": {
      "type": "object",
      "additionalProperties": false,
      "required": ["monte_carlo"],
      "properties": {
        "monte_carlo": { "$ref": "#/$defs/monte_carlo" }
      }
    },

    "monte_carlo": {
      "type": "object",
      "additionalProperties": false,
      "required": ["pfa", "n_trials", "detector", "background"],
      "properties": {
        "seed": { "type": "integer" },
        "pfa": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1 },
        "n_trials": { "type": "integer", "minimum": 1 },
        "detector": {
          "type": "string",
          "enum": ["ca_cfar_independent", "ca_cfar_1d_sliding"]
        },
        "n_ref": { "type": "integer", "minimum": 1 },
        "n_train": { "type": "integer", "minimum": 1 },
        "n_guard": { "type": "integer", "minimum": 0 },
        "n_cells": { "type": "integer", "minimum": 5 },
        "background": { "$ref": "#/$defs/background" }
      }
    },

    "background": {
      "type": "object",
      "additionalProperties": false,
      "required": ["model"],
      "properties": {
        "model": { "type": "string", "enum": ["exponential", "weibull", "lognormal", "k"] },
        "mean_power": { "type": "number", "exclusiveMinimum": 0 },
        "params": { "type": "object", "additionalProperties": true },
        "hetero": { "$ref": "#/$defs/hetero" }
      }
    },

    "hetero": {
      "type": "object",
      "additionalProperties": false,
      "required": ["enabled"],
      "properties": {
        "enabled": { "type": "boolean" },
        "mode": { "type": "string", "enum": ["multiply"] },
        "mean_multiplier": { "type": "number", "exclusiveMinimum": 0 },
        "mean_multiplier_segments": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["value", "count"],
            "properties": {
              "value": { "type": "number", "exclusiveMinimum": 0 },
              "count": { "type": "integer", "minimum": 1 }
            }
          }
        }
      }
    },

    "radar": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fc_hz", "tx_power_w"],
      "properties": {
        "fc_hz": { "type": "number", "exclusiveMinimum": 0 },
        "tx_power_w": { "type": "number", "exclusiveMinimum": 0 },
        "prf_hz": { "type": "number", "exclusiveMinimum": 0 },
        "duty_cycle": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },

    "antenna": {
      "type": "object",
      "additionalProperties": false,
      "required": ["gain_tx_db"],
      "properties": {
        "gain_tx_db": { "type": "number" },
        "gain_rx_db": { "type": "number" }
      }
    },

    "receiver": {
      "type": "object",
      "additionalProperties": false,
      "required": ["bw_hz", "nf_db"],
      "properties": {
        "bw_hz": { "type": "number", "exclusiveMinimum": 0 },
        "nf_db": { "type": "number", "minimum": 0 },
        "temperature_k": { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "target": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rcs_sqm"],
      "properties": {
        "rcs_sqm": { "type": "number", "exclusiveMinimum": 0 }
      }
    },

    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "system_losses_db": { "type": "number", "minimum": 0 }
      }
    },

    "detection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pfa": { "type": "number", "exclusiveMinimum": 0, "exclusiveMaximum": 1 },
        "n_pulses": { "type": "integer", "minimum": 1 },
        "integration": { "type": "string", "enum": ["noncoherent", "coherent"] }
      }
    },

    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ranges_m": {
          "type": "array",
          "items": { "type": "number", "exclusiveMinimum": 0 }
        }
      }
    },

    "geometry": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "n_range_bins": { "type": "integer", "minimum": 1 },
        "n_doppler_bins": { "type": "integer", "minimum": 1 },
        "beams_per_scan": { "type": "integer", "minimum": 1 },
        "n_cpi_per_dwell": { "type": "integer", "minimum": 1 }
      }
    }
  }
}